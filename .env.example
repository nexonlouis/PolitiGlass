# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional for server API routes; ingest script requires this. Migration 005 allows anon read too.
SUPABASE_SERVICE_ROLE_KEY=

# Address → district / officials (at least one recommended)
GEOCODIO_API_KEY=
# Optional: free tier at https://www.civdotiq.org/developers (no key required for basic use)
CIVIQ_API_BASE_URL=https://civdotiq.org/api/v1

# Federal officials (with Census geocoder) + House roll-call votes
CONGRESS_GOV_API_KEY=
# Current Congress number for member lookups (default 119)
CONGRESS_NUMBER=119

# Optional: state + Senate vote coverage
LEGISCAN_API_KEY=

# YouTube curated feed (optional for MVP)
YOUTUBE_API_KEY=

# Set to "true" to return mock officials when upstream APIs are unavailable
# Fallback mock officials only when all live lookups fail
CIVIC_MIRROR_DEMO_MODE=false
